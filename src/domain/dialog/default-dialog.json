      "options": [
        {
          "id": "welcome-ja",
          "label": "Ja, teilnehmen"
        },
        {
          "id": "welcome-nein",
          "label": "Nein, danke"
        }
      ],
      "transitions": [
        {
          "conditions": [
            {
              "field": "teilnahme",
              "operator": "eq",
              "value": "welcome-nein"
